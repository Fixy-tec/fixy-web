# =====================================================
# Plantilla de variables de entorno del BACKEND.
# Copia este archivo a `.env` para desarrollo local.
# En Render, configura cada variable desde el dashboard
# del servicio (NUNCA subas .env al repo).
# =====================================================

# Conexión a la base de datos PostgreSQL (Neon, Render PG, etc.)
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"

# Secreto para firmar JWTs. En producción usa una cadena larga y aleatoria.
JWT_SECRET=replace-me-with-a-long-random-string

# Lista (separada por comas) de orígenes permitidos por CORS. En producción
# pon SOLO los dominios de tu frontend en Vercel, p.ej.:
#   https://fixy-web.vercel.app,https://fixy-web-staging.vercel.app
# En dev puedes incluir además http://localhost:3000.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Render inyecta su propio PORT automáticamente. En local usamos 4000.
PORT=4000
