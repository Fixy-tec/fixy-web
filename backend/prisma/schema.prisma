generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()"))
  email                  String                  @unique
  password               String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  points                 Int                     @default(0)
  isActive               Boolean                 @default(true)
  medal                  Medal                   @default(HIERRO)
  name                   String
  role                   Role                    @default(USER)
  applications           Application[]           @relation("AppliedBy")
  deviceTokens           DeviceToken[]
  notificationRecipients NotificationRecipient[]
  pointLogs              PointLog[]
  profile                Profile?
  ratingsReceived        Rating[]                @relation("ReceivedBy")
  ratingsGiven           Rating[]                @relation("GivenBy")
  requestsCreated        Request[]               @relation("CreatedBy")
  userTags               UserTag[]

  @@index([email])
  @@index([createdAt])
}

model Profile {
  id           String  @id @default(dbgenerated("gen_random_uuid()"))
  userId       String  @unique
  career       String  @default("Desarrollo de Software")
  cycle        Int?
  whatsapp     String?
  avatarUrl    String?
  avgRating    Float   @default(0)
  bio          String?
  institution  String?
  linkedinUrl  String?
  portfolioUrl String?
  githubUrl    String?
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tag {
  id        String       @id @default(dbgenerated("gen_random_uuid()"))
  name      String       @unique
  createdAt DateTime     @default(now())
  isCustom  Boolean      @default(false)
  requests  RequestTag[]
  users     UserTag[]
}

model UserTag {
  userId     String
  tagId      String
  assignedAt DateTime @default(now())
  tag        Tag      @relation(fields: [tagId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@id([userId, tagId])
}

model RequestTag {
  requestId String
  tagId     String
  request   Request @relation(fields: [requestId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([requestId, tagId])
}

model Request {
  id                 String        @id @default(dbgenerated("gen_random_uuid()"))
  type               RequestType
  title              String
  description        String
  difficulty         Int           @db.SmallInt
  status             RequestStatus @default(ABIERTA)
  createdAt          DateTime      @default(now())
  deadline           DateTime?
  basePoints         Int
  creatorId          String
  economicBenefit    Float?
  participantsNeeded Int           @default(1)
  updatedAt          DateTime      @updatedAt
  isExpired          Boolean       @default(false)
  applications       Application[] @relation("AppliedTo")
  pointLogs          PointLog[]
  creator            User          @relation("CreatedBy", fields: [creatorId], references: [id], onDelete: Cascade)
  tags               RequestTag[]

  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
  @@index([difficulty])
}

model Application {
  id          String            @id @default(dbgenerated("gen_random_uuid()"))
  requestId   String
  message     String
  status      ApplicationStatus @default(PENDIENTE)
  createdAt   DateTime          @default(now())
  applicantId String
  updatedAt   DateTime          @updatedAt
  applicant   User              @relation("AppliedBy", fields: [applicantId], references: [id], onDelete: Cascade)
  request     Request           @relation("AppliedTo", fields: [requestId], references: [id], onDelete: Cascade)
  ratings     Rating[]

  @@unique([requestId, applicantId])
  @@index([requestId])
  @@index([applicantId])
  @@index([status])
  @@index([createdAt])
}

model Rating {
  id              String      @id @default(dbgenerated("gen_random_uuid()"))
  applicationId   String
  comment         String?
  createdAt       DateTime    @default(now())
  ratedId         String
  raterId         String
  stars           Int         @db.SmallInt
  isAutoGenerated Boolean     @default(false)
  pointLogs       PointLog[]
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  rated           User        @relation("ReceivedBy", fields: [ratedId], references: [id], onDelete: Cascade)
  rater           User        @relation("GivenBy", fields: [raterId], references: [id], onDelete: Cascade)

  @@unique([applicationId, raterId])
  @@index([raterId])
  @@index([ratedId])
  @@index([createdAt])
}

model PointLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  userId      String
  ratingId    String?
  requestId   String?
  delta       Int
  reason      String
  medalBefore Medal?
  medalAfter  Medal?
  createdAt   DateTime @default(now())
  rating      Rating?  @relation(fields: [ratingId], references: [id])
  request     Request? @relation(fields: [requestId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id         String                  @id @default(uuid())
  type       NotificationType
  data       Json?
  createdAt  DateTime                @default(now())
  message    String
  title      String
  updatedAt  DateTime                @updatedAt
  recipients NotificationRecipient[]
}

model NotificationRecipient {
  notificationId String
  userId         String
  read           Boolean      @default(false)
  readAt         DateTime?
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([notificationId, userId])
  @@index([userId])
  @@index([notificationId])
  @@index([read])
}

model DeviceToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum RequestType {
  ASESORIA
  PROYECTO
}

enum RequestStatus {
  ABIERTA
  EN_REVISION
  EN_PROCESO
  COMPLETADA
  CANCELADA
}

enum ApplicationStatus {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

enum NotificationType {
  APPLICATION_RECEIVED
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  REQUEST_COMPLETED
  NEW_MATCH
  RANK_UP
}

enum Role {
  USER
  ADMIN
}

enum Medal {
  HIERRO
  BRONCE
  PLATA
  ORO
  DIAMANTE
  MAESTRO
  CHALLENGER
}
