// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")

}

//////////////////////
// ENUMS
//////////////////////

enum RequestType {
  ASESORIA
  PROYECTO
}

enum RequestStatus {
  ABIERTA
  EN_REVISION
  EN_PROCESO
  COMPLETADA
  CANCELADA
}

enum ApplicationStatus {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

enum NotificationType {
  APPLICATION_RECEIVED
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  REQUEST_COMPLETED
  NEW_MATCH
  RANK_UP
}

enum Role {
  USER
  ADMIN
}

enum Medal {
  HIERRO
  BRONCE
  PLATA
  ORO
  DIAMANTE
  MAESTRO
  CHALLENGER
}

//////////////////////
// USER
//////////////////////

model User {
  id String @id @default(dbgenerated("gen_random_uuid()"))
  email       String   @unique
  password    String
  isActive    Boolean  @default(true)

  role        Role @default(USER)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile     Profile?
  userTags UserTag[]

  requests    Request[]
  applications Application[]

  ratingsGiven    Rating[] @relation("given")
  ratingsReceived Rating[] @relation("received")

  pointLogs PointLog[]

  notifications Notification[]
  deviceTokens DeviceToken[]

  points      Int     @default(0)
  medal       Medal   @default(HIERRO)
}

//////////////////////
// PROFILE
//////////////////////

model Profile {
  id            String @id @default(dbgenerated("gen_random_uuid()"))
  userId        String  @unique

  fullName      String?
  institution   String?
  career        String?
  cycle         Int?

  bio           String?
  avatarUrl     String?
  whatsapp      String?
  portfolioUrl  String?
  linkedinUrl   String?
  githubUrl     String?

  avgRating     Float   @default(0)

  user User @relation(fields: [userId], references: [id])
}

//////////////////////
// TAGS
//////////////////////

model Tag {
  id        String @id @default(dbgenerated("gen_random_uuid()"))
  name      String @unique
  isCustom  Boolean @default(false)

  createdAt DateTime @default(now())

  users     UserTag[]
  requests  RequestTag[]
}

model UserTag {
  userId String
  tagId  String

  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  tag  Tag  @relation(fields: [tagId], references: [id])

  @@id([userId, tagId])
}

model RequestTag {
  requestId String
  tagId     String

  request Request @relation(fields: [requestId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([requestId, tagId])
}

//////////////////////
// REQUEST
//////////////////////

model Request {
  id          String @id @default(dbgenerated("gen_random_uuid()"))
  creatorId   String

  type        RequestType
  title       String
  description String

  difficulty  Int
  basePoints  Int
  economicBenefit Float?

  participantsNeeded Int @default(1)

  status      RequestStatus @default(ABIERTA)
  deadline    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  selectedApplicationId String? @unique

  creator User @relation(fields: [creatorId], references: [id])
  selectedApplication   Application? @relation("SelectedApplication", fields: [selectedApplicationId], references: [id])

  applications Application[]
  tags         RequestTag[]

  pointLogs    PointLog[]

  isExpired Boolean @default(false)

  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
}

//////////////////////
// APPLICATION
//////////////////////

model Application {
  id          String @id @default(dbgenerated("gen_random_uuid()"))
  requestId   String
  applicantId String

  message     String
  status ApplicationStatus @default(PENDIENTE)

  createdAt   DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id])
  applicant User @relation(fields: [applicantId], references: [id])
  selectedIn Request? @relation("SelectedApplication")

  rating Rating?

  @@unique([requestId, applicantId])
  @@index([requestId])
  @@index([applicantId])
}

//////////////////////
// RATING
//////////////////////

model Rating {
  id            String @id @default(dbgenerated("gen_random_uuid()"))
  applicationId String @unique

  raterId       String
  ratedId       String

  stars         Int
  comment       String?

  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])

  rater User @relation("given", fields: [raterId], references: [id])
  rated User @relation("received", fields: [ratedId], references: [id])

  pointLogs PointLog[]

  isAutoGenerated Boolean @default(false)
}

//////////////////////
// POINT LOG
//////////////////////

model PointLog {
  id        String @id @default(dbgenerated("gen_random_uuid()"))

  userId    String
  ratingId  String?
  requestId String?

  delta     Int
  reason    String

  medalBefore Medal?
  medalAfter  Medal?

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  request   Request? @relation(fields: [requestId], references: [id])
  rating Rating? @relation(fields: [ratingId], references: [id])
}

//////////////////////
// NOTIFICATION
//////////////////////

model Notification {
  id        String @id @default(dbgenerated("gen_random_uuid()"))
  userId    String

  type      NotificationType
  data      Json?

  read      Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//////////////////////
// PUSH
//////////////////////

model DeviceToken {
  id       String @id @default(dbgenerated("gen_random_uuid()"))
  userId   String

  token    String @unique
  platform String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}