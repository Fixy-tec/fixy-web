// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")

}

//////////////////////
// ENUMS
//////////////////////

enum RequestType {
  ASESORIA
  PROYECTO
}

enum RequestStatus {
  ABIERTA
  EN_REVISION
  EN_PROCESO
  COMPLETADA
  CANCELADA
}

enum ApplicationStatus {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

enum NotificationType {
  APPLICATION_RECEIVED
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  REQUEST_COMPLETED
  NEW_MATCH
  RANK_UP
}

enum Role {
  USER
  ADMIN
}

enum Medal {
  HIERRO
  BRONCE
  PLATA
  ORO
  DIAMANTE
  MAESTRO
  CHALLENGER
}

//////////////////////
// USER
//////////////////////

model User {
  id          String @id @default(dbgenerated("gen_random_uuid()"))
  name        String
  email       String   @unique
  password    String
  isActive    Boolean  @default(true)

  role        Role @default(USER)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // One-to-One: User -> Profile
  profile     Profile?
  
  // Many-to-Many: User -> Tag (user interests/skills)
  userTags    UserTag[]

  // One-to-Many: User creates many Requests (max 5 active)
  requestsCreated  Request[] @relation("CreatedBy")
  
  // One-to-Many: User sends many Applications
  applications Application[] @relation("AppliedBy")

  // One-to-Many: User gives ratings (as rater)
  ratingsGiven    Rating[] @relation("GivenBy")
  
  // One-to-Many: User receives ratings (as rated)
  ratingsReceived Rating[] @relation("ReceivedBy")

  // One-to-Many: Point logs for this user
  pointLogs   PointLog[]

  // One-to-Many: Notifications for this user
  notifications Notification[]
  
  // One-to-Many: Device tokens for push notifications
  deviceTokens DeviceToken[]

  // User stats
  points      Int     @default(0)
  medal       Medal   @default(HIERRO)

  @@index([email])
  @@index([createdAt])
}

//////////////////////
// PROFILE
//////////////////////

model Profile {
  id            String @id @default(dbgenerated("gen_random_uuid()"))
  userId        String  @unique

  institution   String?
  career        String @default("Desarrollo de Software") 
  cycle         Int?

  bio           String?
  avatarUrl     String?
  whatsapp      String
  portfolioUrl  String?
  linkedinUrl   String?
  githubUrl     String?

  avgRating     Float   @default(0)

  user User @relation(fields: [userId], references: [id])
}

//////////////////////
// TAGS
//////////////////////

model Tag {
  id        String @id @default(dbgenerated("gen_random_uuid()"))
  name      String @unique
  isCustom  Boolean @default(false)

  createdAt DateTime @default(now())

  users     UserTag[]
  requests  RequestTag[]
}

model UserTag {
  userId String
  tagId  String

  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  tag  Tag  @relation(fields: [tagId], references: [id])

  @@id([userId, tagId])
}

model RequestTag {
  requestId String
  tagId     String

  request Request @relation(fields: [requestId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([requestId, tagId])
}

//////////////////////
// REQUEST
//////////////////////

model Request {
  id          String @id @default(dbgenerated("gen_random_uuid()"))
  
  // Foreign key to User (creator)
  creatorId   String

  type        RequestType
  title       String
  description String

  difficulty  Int @db.SmallInt // 1-5
  basePoints  Int
  economicBenefit Float?

  participantsNeeded Int @default(1)

  status      RequestStatus @default(ABIERTA)
  deadline    DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Selected application when request is accepted
  selectedApplicationId String? @unique

  // Many-to-One: Request -> User (creator, max 5 active per user)
  creator User @relation("CreatedBy", fields: [creatorId], references: [id], onDelete: Cascade)
  
  // One-to-Many: Request has many Applications (applicants)
  applications Application[] @relation("AppliedTo")
  
  // One: Request selected one Application
  selectedApplication Application? @relation("SelectedApplication", fields: [selectedApplicationId], references: [id], onDelete: SetNull)

  // Many-to-Many: Request has many Tags (project skills/areas)
  tags         RequestTag[]

  // One-to-Many: Point logs for this request
  pointLogs    PointLog[]

  isExpired   Boolean @default(false)

  @@index([creatorId])
  @@index([status])
  @@index([createdAt])
  @@index([difficulty])
}

//////////////////////
// APPLICATION
//////////////////////

model Application {
  id          String @id @default(dbgenerated("gen_random_uuid()"))
  
  // Foreign keys
  requestId   String
  applicantId String

  message     String
  status      ApplicationStatus @default(PENDIENTE)

  createdAt   DateTime @default(now())

  // Many-to-One: Application -> Request (many applications per request)
  request     Request @relation("AppliedTo", fields: [requestId], references: [id], onDelete: Cascade)
  
  // Many-to-One: Application -> User (applicant, many applications per user)
  applicant   User @relation("AppliedBy", fields: [applicantId], references: [id], onDelete: Cascade)
  
  // One: Application can be the selectedApplication of a Request
  selectedIn  Request? @relation("SelectedApplication")

  // One-to-One: Application generates one Rating (optional, only if completed)
  rating      Rating?

  @@unique([requestId, applicantId])
  @@index([requestId])
  @@index([applicantId])
  @@index([status])
  @@index([createdAt])
}

//////////////////////
// RATING
//////////////////////

model Rating {
  id            String @id @default(dbgenerated("gen_random_uuid()"))
  
  // Foreign keys
  applicationId String @unique
  raterId       String
  ratedId       String

  stars         Int @db.SmallInt // 1-5
  comment       String?

  createdAt     DateTime @default(now())

  // One-to-One: Rating -> Application
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Many-to-One: Rating -> User (rater, the one giving the rating)
  rater         User @relation("GivenBy", fields: [raterId], references: [id], onDelete: Cascade)
  
  // Many-to-One: Rating -> User (rated, the one receiving the rating)
  rated         User @relation("ReceivedBy", fields: [ratedId], references: [id], onDelete: Cascade)

  // One-to-Many: Rating generates PointLog entries
  pointLogs     PointLog[]

  isAutoGenerated Boolean @default(false)

  @@index([raterId])
  @@index([ratedId])
  @@index([createdAt])
}

//////////////////////
// POINT LOG
//////////////////////

model PointLog {
  id        String @id @default(dbgenerated("gen_random_uuid()"))

  userId    String
  ratingId  String?
  requestId String?

  delta     Int
  reason    String

  medalBefore Medal?
  medalAfter  Medal?

  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  request   Request? @relation(fields: [requestId], references: [id])
  rating Rating? @relation(fields: [ratingId], references: [id])
}

//////////////////////
// NOTIFICATION
//////////////////////

model Notification {
  id        String @id @default(dbgenerated("gen_random_uuid()"))
  userId    String

  type      NotificationType
  data      Json?

  read      Boolean @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//////////////////////
// PUSH
//////////////////////

model DeviceToken {
  id       String @id @default(dbgenerated("gen_random_uuid()"))
  userId   String

  token    String @unique
  platform String

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}